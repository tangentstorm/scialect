#!/usr/bin/env bash
set -euo pipefail

if ! command -v jq >/dev/null 2>&1; then
    echo "Error: jq is required but not installed." >&2
    exit 1
fi

if [[ ! -f workers.jsonl ]]; then
    echo "Error: workers.jsonl not found in current directory." >&2
    exit 1
fi

jq -r '.id + " " + .dir' workers.jsonl | while read -r id dir; do
    dir="${dir/#\~/$HOME}"

    if [[ ! -d "$dir/.git" ]]; then
        echo "$id: no git repo at $dir"
        continue
    fi

    (
        cd "$dir"

        # Fetch quietly, ignore errors (e.g. no network)
        git fetch origin --quiet 2>/dev/null || true

        if ! git rev-parse --verify origin/main >/dev/null 2>&1; then
            echo "$id: origin/main not found"
            exit 0
        fi

        ahead=$(git rev-list --count origin/main..HEAD 2>/dev/null || echo 0)
        behind=$(git rev-list --count HEAD..origin/main 2>/dev/null || echo 0)

        if [[ $ahead -eq 0 && $behind -eq 0 ]]; then
            status="up to date"
        else
            status="ahead $ahead, behind $behind"
        fi

        echo "$id: $status"
    )
done
